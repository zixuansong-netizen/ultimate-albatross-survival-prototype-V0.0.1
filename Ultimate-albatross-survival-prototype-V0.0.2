// Spawn stones in EVERY chunk
function spawnStonesInChunk(cx, cz) {
    const key = `stones_${cx},${cz}`;
    if (houseData.has(key)) return;

    const worldOffsetX = cx * FLIGHT.chunkSize;
    const worldOffsetZ = cz * FLIGHT.chunkSize;
    const placedPositions = [];

    // Spawn 2-4 stones per chunk
    const numStones = Math.random() < 0.4 ? 3 : 2;

    for (let i = 0; i < numStones; i++) {
        let attempts = 0;
        let placed = false;

        while (attempts < 25 && !placed) {
            attempts++;

            const localX = (Math.random() - 0.5) * (FLIGHT.chunkSize - 50);
            const localZ = (Math.random() - 0.5) * (FLIGHT.chunkSize - 50);

            const worldX = worldOffsetX + localX;
            const worldZ = worldOffsetZ + localZ;

            const { height } = getTerrainHeightAndBiome(worldX, worldZ);

            if (height <= FLIGHT.waterLevel + 2) continue;

            // Check distance from other stones
            let tooClose = false;
            for (const pos of placedPositions) {
                if (Math.hypot(worldX - pos.x, worldZ - pos.z) < STONE_MIN_DISTANCE * 2) {
                    tooClose = true;
                    break;
                }
            }

            if (!tooClose) {
                createStone(worldX, height, worldZ);
                placedPositions.push({ x: worldX, z: worldZ });
                placed = true;
            }
        }
    }

    houseData.set(key, true);
}
function spawnTreesInChunk(cx, cz) {
    const key = `trees_${cx},${cz}`;
    if (houseData.has(key)) return;

    const centerBiome = getTerrainHeightAndBiome(
        cx * FLIGHT.chunkSize + FLIGHT.chunkSize/2,
        cz * FLIGHT.chunkSize + FLIGHT.chunkSize/2
    ).biome;

    if (centerBiome === 'taiga') return;

    const worldOffsetX = cx * FLIGHT.chunkSize;
    const worldOffsetZ = cz * FLIGHT.chunkSize;
    const placedPositions = [];

    for (let i = 0; i < 3; i++) {
        let attempts = 0;
        let placed = false;

        while (attempts < 20 && !placed) {
            attempts++;

            const localX = (Math.random() - 0.5) * (FLIGHT.chunkSize - 40);
            const localZ = (Math.random() - 0.5) * (FLIGHT.chunkSize - 40);

            const worldX = worldOffsetX + localX;
            const worldZ = worldOffsetZ + localZ;

            const { height, biome } = getTerrainHeightAndBiome(worldX, worldZ);

            if (height <= FLIGHT.waterLevel + 3 || biome === 'taiga') continue;

            let tooClose = false;
            for (const pos of placedPositions) {
                if (Math.hypot(worldX - pos.x, worldZ - pos.z) < TREE_MIN_DISTANCE * 2) {
                    tooClose = true;
                    break;
                }
            }

            if (!tooClose) {
                createPalmTree(worldX, height, worldZ);
                placedPositions.push({ x: worldX, z: worldZ });
                placed = true;
            }
        }
    }

    houseData.set(key, true);
}
function updateHunters(delta) {
    const now = Date.now();

    for (let i = hunters.length - 1; i >= 0; i--) {
        const h = hunters[i];
        if (!h || !h.userData) continue;

        const data = h.userData;

        const dx = camera.position.x - h.position.x;
        const dz = camera.position.z - h.position.z;
        const dist = Math.hypot(dx, dz);

        // Chase player if close
        if (dist < 80 && dist > 3) {
            const speed = 12;
            h.position.x += (dx / dist) * speed * delta;
            h.position.z += (dz / dist) * speed * delta;

            // Face player
            h.lookAt(camera.position.x, h.position.y + 3, camera.position.z);
        }

        // Hunter attacks player
        if (dist < 4 && now - (data.lastAttack || 0) > 1200) {
            if (now - (lastPlayerHitTime || 0) > 800) {
                playerHealth = Math.max(0, playerHealth - 1);
                lastPlayerHitTime = now;

                const warning = document.getElementById('takeoffWarning');
                warning.innerHTML = `🩸 HUNTER ATTACK! -1 HP`;
                warning.style.opacity = '1';
                warning.style.color = '#ff5555';
                setTimeout(() => warning.style.opacity = '0', 900);
            }
            data.lastAttack = now;
        }

        // === NEW RAMMING ATTACK SYSTEM ===
        // Damage = speedKmh / 2  (faster = more damage)
        if (dist < 8 && keys['click'] && now - (lastAttackTime || 0) > 600) {
            keys['click'] = false;
            lastAttackTime = now;

            const horizontalSpeed = Math.hypot(velocity.x, velocity.z);
            const speedKmh = horizontalSpeed * 3.6;
            const damage = Math.max(1, Math.floor(speedKmh / 2));

            data.health = (data.health || 5) - damage;

            // Bleed effect
            createBloodParticles(h.position.x, h.position.y + 3.5, h.position.z);

            // Feedback message
            const warning = document.getElementById('takeoffWarning');
            warning.innerHTML = `💥 RAM HIT! -${damage} DMG (${data.health}/5)`;
            warning.style.opacity = '1';
            warning.style.color = speedKmh > 60 ? '#ff4444' : '#ffff66';

            setTimeout(() => {
                warning.style.opacity = '0';
            }, 700);

            if (data.health <= 0) {
                scene.remove(h);
                hunters.splice(i, 1);

                const deathMsg = document.getElementById('takeoffWarning');
                deathMsg.innerHTML = `💀 HUNTER DEFEATED!`;
                deathMsg.style.opacity = '1';
                deathMsg.style.color = '#aaffaa';
                setTimeout(() => deathMsg.style.opacity = '0', 1400);
            }
        }
    }
}

// Simple blood particles
function createBloodParticles(x, y, z) {
    for (let i = 0; i < 8; i++) {
        const p = new THREE.Mesh(
            new THREE.SphereGeometry(0.15, 4, 4),
            new THREE.MeshStandardMaterial({ color: 0xaa0000 })
        );
        p.position.set(x, y, z);
        p.userData = {
            life: 1.2 + Math.random(),
            vel: new THREE.Vector3(
                (Math.random() - 0.5) * 12,
                6 + Math.random() * 8,
                (Math.random() - 0.5) * 12
            )
        };
        scene.add(p);
        bloodParticles.push(p);
    }
}

function updateBloodParticles(delta) {
    for (let i = bloodParticles.length - 1; i >= 0; i--) {
        const p = bloodParticles[i];
        p.userData.vel.y -= 25 * delta;
        p.position.addScaledVector(p.userData.vel, delta);
        p.userData.life -= delta;

        if (p.userData.life <= 0) {
            scene.remove(p);
            bloodParticles.splice(i, 1);
        }
    }
}
// Wind sway + hit shake
function updateTreeSway(delta) {
    const time = performance.now() * 0.001;
    for (let tree of trees) {
        if (!tree || !tree.userData || tree.userData.isFalling) continue;
        const data = tree.userData;

        const sway = Math.sin(time * 1.2 + data.swayTime) * 0.035;
        tree.rotation.z = sway;
        tree.rotation.x = Math.sin(time * 0.9 + data.swayTime) * 0.025;

        if (data.shakeIntensity > 0.01) {
            const shakeX = (Math.random() - 0.5) * data.shakeIntensity * 0.15;
            const shakeZ = (Math.random() - 0.5) * data.shakeIntensity * 0.15;
            tree.rotation.z += shakeX;
            tree.rotation.x += shakeZ;
            data.shakeIntensity *= 0.92;
        }
    }
}

