function createChunk(cx, cz) {
    const key = `${cx},${cz}`;
    if (chunks.has(key)) return;

    const geometry = new THREE.PlaneGeometry(FLIGHT.chunkSize, FLIGHT.chunkSize, 14, 14);
    geometry.rotateX(-Math.PI/2);
    const positions = geometry.attributes.position.array;

    for (let i = 0; i < positions.length; i += 3) {
        const lx = positions[i], lz = positions[i+2];
        const worldX = cx * FLIGHT.chunkSize + lx;
        const worldZ = cz * FLIGHT.chunkSize + lz;

        const { height, biome } = getTerrainHeightAndBiome(worldX, worldZ);
        positions[i+1] = height;
    }
    geometry.computeVertexNormals();

    const centerBiomeData = getTerrainHeightAndBiome(
        cx * FLIGHT.chunkSize + FLIGHT.chunkSize/2,
        cz * FLIGHT.chunkSize + FLIGHT.chunkSize/2
    );
    const biome = centerBiomeData.biome;

    let mat;
    if (biome === 'taiga') mat = new THREE.MeshStandardMaterial({ map: T.taigaTex, roughness: 0.9 });
    else if (biome === 'savanna') mat = new THREE.MeshStandardMaterial({ map: T.savannaTex, roughness: 0.92 });
    else if (biome === 'desert') mat = new THREE.MeshStandardMaterial({ map: T.desertTex, roughness: 0.95 });
    else mat = new THREE.MeshStandardMaterial({ map: T.grassTex, roughness: 0.88 });

    const terrain = new THREE.Mesh(geometry, mat);
    terrain.position.set(cx * FLIGHT.chunkSize, 0, cz * FLIGHT.chunkSize);
    scene.add(terrain);

    // === SMART GRASS SPAWNING ===
    let grassGroup = null;
    if (biome !== 'desert') {
        grassGroup = new THREE.Group();
        const grassMat = new THREE.MeshStandardMaterial({ color: 0x6a9a4a });

        const isSpawnChunk = (cx === spawnChunkX && cz === spawnChunkZ);
        const grassCount = isSpawnChunk ? 30 : 280;

        for (let i = 0; i < grassCount; i++) {
            const lx = (Math.random() - 0.5) * (FLIGHT.chunkSize - 20);
            const lz = (Math.random() - 0.5) * (FLIGHT.chunkSize - 20);
            const h = getTerrainHeightAndBiome(cx * FLIGHT.chunkSize + lx, cz * FLIGHT.chunkSize + lz).height;

            if (h > FLIGHT.waterLevel + 0.8) {
                const blade = new THREE.Mesh(new THREE.CylinderGeometry(0.08, 0.12, 0.5 + Math.random() * 0.6, 3), grassMat);
                blade.position.set(lx, h + 0.3, lz);
                grassGroup.add(blade);
            }
        }
        scene.add(grassGroup);
    }

    spawnHousesInChunk(cx, cz);
    spawnTreesInChunk(cx, cz);
    spawnStonesInChunk(cx, cz);
    spawnIronOreInChunk(cx, cz);      // ← add
    spawnTungstenOreInChunk(cx, cz);  // ← add


    chunks.set(key, { terrain, grass: grassGroup });

    chunks.set(key, { terrain, grass: grassGroup });

    // === HUNTER SPAWNING (only at night) ===
    spawnHunterInChunk(cx, cz);

    chunks.set(key, { terrain, grass: grassGroup });
}
