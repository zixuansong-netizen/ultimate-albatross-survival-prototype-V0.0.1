        thermalStrength = 0;
        if (isOverSavanna && !isOnGround && camera.position.y < 100) {
            const thermalNoise = perlin3D(camera.position.x * 0.025, camera.position.z * 0.025, 0);
            if (thermalNoise > 0.55) thermalStrength = FLIGHT.thermalLift * (thermalNoise - 0.5) * 1.6;
        }
        document.getElementById('thermalValue').innerHTML = thermalStrength > 0.5 ? `⬆️ ${thermalStrength.toFixed(1)}` : 'NONE';

        let glideLift = 0;
        if (!isOnGround && horizontalSpeed > 3) glideLift = horizontalSpeed / FLIGHT.glideRatio;

        // FLAP
        if (flapPressed && (Date.now() - lastFlapTime > 300) && !isOnGround) {
            const slot = inventory[selectedHotbar];
            if (slot && slot.type === 'flap' && slot.count > 0) {
                slot.count--;
                lastFlapTime = Date.now();
                velocity.y += FLIGHT.flapForce;
                const forwardDir = new THREE.Vector3(Math.sin(yaw), 0, Math.cos(yaw));
                velocity.x += forwardDir.x * 2.0;
                velocity.z += forwardDir.z * 2.0;
                renderHotbar();
                renderFullInventory();
            }
        }

        // FLAP REGEN
        if (spaceHeld && !isOnGround) {
            flapRegenTimer += delta;
            if (flapRegenTimer >= 4.5) {
                flapRegenTimer = 0;
                for (let i = 0; i < inventory.length; i++) {
                    const slot = inventory[i];
                    if (slot && slot.type === 'flap' && slot.count < ITEM_DB.flap.maxStack) {
                        slot.count++;
                        renderHotbar();
                        renderFullInventory();
                        break;
                    }
                }
            }
        } else flapRegenTimer = 0;

        // JET
        const now = Date.now();
        const isBoosting = now < jetBoostEndTime;
        if (jetPressed && !isOnGround && !isBoosting) {
            const slot = inventory[selectedHotbar];
            if (slot && slot.type === 'jet' && slot.count > 0) {
                slot.count--;
                jetBoostEndTime = now + FLIGHT.jetDuration * 1000;
                const boostDir = new THREE.Vector3(0, 0, -1).applyQuaternion(camera.quaternion).normalize();
                velocity.addScaledVector(boostDir, 12);
                renderHotbar();
                renderFullInventory();
                jetPressed = false;
            }
        }
        if (isBoosting) {
            const boostDir = new THREE.Vector3(0, 0, -1).applyQuaternion(camera.quaternion).normalize();
            velocity.addScaledVector(boostDir, FLIGHT.jetBoostAccel * delta);
        }

        let netLift = FLIGHT.gravity + glideLift + thermalStrength;
        velocity.y += netLift * delta;
        velocity.x *= FLIGHT.airDrag;
        velocity.z *= FLIGHT.airDrag;

        if (!isOnGround && speedKmh < FLIGHT.minAirSpeed) velocity.y -= 3 * delta;

        if (isOnGround) {
            if (move.forward && spaceHeld) {
                takeoffRunSpeed += FLIGHT.groundAccel * delta;
                takeoffRunSpeed = Math.min(takeoffRunSpeed, FLIGHT.takeoffSpeed + 5);
                const runDir = new THREE.Vector3(Math.sin(yaw), 0, Math.cos(yaw));
                velocity.x = runDir.x * (takeoffRunSpeed / 3.6);
                velocity.z = runDir.z * (takeoffRunSpeed / 3.6);
                const warning = document.getElementById('takeoffWarning');
                if (takeoffRunSpeed >= FLIGHT.takeoffSpeed) warning.style.opacity = '0';
                else if (takeoffRunSpeed > 15) {
                    warning.style.opacity = '0.8';
                    warning.innerHTML = `🏃 RUNNING: ${Math.floor(takeoffRunSpeed)}/${FLIGHT.takeoffSpeed} km/h 🏃`;
                } else warning.style.opacity = '0.5';
            } else {
                takeoffRunSpeed *= 0.96;
                velocity.x *= 0.96;
                velocity.z *= 0.96;
                document.getElementById('takeoffWarning').style.opacity = '0';
            }

            if (takeoffRunSpeed >= FLIGHT.takeoffSpeed && spaceHeld && move.forward) {
                isOnGround = false;
                velocity.y = 7.0;
                takeoffRunSpeed = 0;
                document.getElementById('takeoffWarning').innerHTML = '🚀 LIFT OFF! 🚀';
                document.getElementById('takeoffWarning').style.opacity = '1';
                setTimeout(() => {
                    document.getElementById('takeoffWarning').style.opacity = '0';
                    document.getElementById('takeoffWarning').innerHTML = '🏃‍♂️ RUN TO 28 KM/H TO TAKE OFF! HOLD W + SPACE 🏃‍♂️';
                }, 1500);
            }
        }

        isGliding = spaceHeld && !isOnGround;

        if (isOnGround) {
            const moveDir = new THREE.Vector3();
            if (move.forward) moveDir.z -= 1;
            if (move.backward) moveDir.z += 1;
            if (move.left) moveDir.x -= 1;
            if (move.right) moveDir.x += 1;
            if (moveDir.length() > 0) moveDir.normalize();
            const forwardDir = new THREE.Vector3(0, 0, -1).applyQuaternion(camera.quaternion);
            const rightDir = new THREE.Vector3(1, 0, 0).applyQuaternion(camera.quaternion);
            let horiz = new THREE.Vector3().addScaledVector(forwardDir, -moveDir.z).addScaledVector(rightDir, moveDir.x);
            horiz.y = 0;
            if (horiz.length() > 0) horiz.normalize();
            const targetSpeed = 20;
            const targetVelX = horiz.x * targetSpeed;
            const targetVelZ = horiz.z * targetSpeed;
            const steering = 4.5;
            velocity.x += (targetVelX - velocity.x) * steering * delta;
            velocity.z += (targetVelZ - velocity.z) * steering * delta;
        } else {
            const lookDir = new THREE.Vector3(0, 0, -1).applyQuaternion(camera.quaternion).normalize();
            const currentSpeed = velocity.length();
            if (currentSpeed > 0.5) {
                const targetVel = lookDir.multiplyScalar(currentSpeed);
                velocity.lerp(targetVel, FLIGHT.alignmentStrength);
            }
        }

        camera.position.x += velocity.x * delta;
        camera.position.z += velocity.z * delta;
        camera.position.y += velocity.y * delta;

        // ==================== GROUND COLLISION + CRASH DETECTION ====================
        const wasOnGround = isOnGround;

        // Reuse terrainH that was already calculated at the top
        if (camera.position.y - 1.3 <= terrainH) {
            camera.position.y = terrainH + 1.3;
            velocity.y = 0;
            isOnGround = true;
        } else {
            isOnGround = false;
        }

        // Trigger crash damage only when we just landed this frame
        if (wasOnGround === false && isOnGround === true) {
            checkCrashDamage();
        }


        if (camera.position.y > 200) camera.position.y = 200;

        let status = isOnGround ? '🪹 GROUNDED' : (isBoosting ? '🚀 JET BOOSTING' : (isGliding ? '🕊️ GLIDING' : '🌀 FLYING'));
        if (isOnGround && move.forward && spaceHeld && takeoffRunSpeed > 0) {
            status = `🏃 TAKEOFF (${Math.floor(takeoffRunSpeed)}/${FLIGHT.takeoffSpeed} km/h)`;
        }
        document.getElementById('flightStatus').innerHTML = status;
        document.getElementById('biomeTag').innerHTML = biome.toUpperCase();
    }

function updateHealth(delta) {
    const now = Date.now();

    // Passive regeneration: +1 HP every second
    if (now - lastRegenTime >= 1000) {
        if (playerHealth < MAX_HEALTH) {
            playerHealth = Math.min(MAX_HEALTH, playerHealth + 1);
        }
        lastRegenTime = now;
    }

    // Update UI
    const healthPercent = (playerHealth / MAX_HEALTH) * 100;
    const healthFill = document.getElementById('healthFill');
    const healthText = document.getElementById('healthText');

    healthFill.style.width = healthPercent + '%';
    healthText.innerHTML = Math.floor(playerHealth) + " / 150";

    // Low health warning color
    if (playerHealth < 40) {
        healthFill.style.background = 'linear-gradient(90deg, #ff0000, #ff8800)';
    } else {
        healthFill.style.background = 'linear-gradient(90deg, #ff5555, #ffaa77)';
    }
}
function checkCrashDamage() {
    const horizontalSpeed = Math.hypot(velocity.x, velocity.z);
    const speedKmh = horizontalSpeed * 3.6;

    // New logic: Only damage if going faster than 60 km/h
    if (speedKmh > 60) {
        const damage = Math.max(1, Math.floor((speedKmh - 60) / 2));

        playerHealth = Math.max(0, playerHealth - damage);

        // Visual feedback
        const warning = document.getElementById('takeoffWarning');
        warning.innerHTML = `💥 HARD LANDING! -${damage} HP`;
        warning.style.opacity = '1';
        warning.style.borderColor = '#ff0000';
        warning.style.color = '#ff5555';

        setTimeout(() => {
            warning.style.opacity = '0';
        }, 1800);

        console.log(`💥 Crash damage: ${damage} HP at ${Math.floor(speedKmh)} km/h`);
    }
}

        // Update UI
        const healthPercent = (playerHealth / MAX_HEALTH) * 100;   // ← DELETE THIS BLOCK
        document.getElementById('healthFill').style.width = healthPercent + '%';
        document.getElementById('healthText').innerHTML = Math.floor(playerHealth) + " / 150";

        // Visual warning when low
        if (playerHealth < 40) {
            document.getElementById('healthFill').style.background = 'linear-gradient(90deg, #ff0000, #ff8800)';
        } else {
            document.getElementById('healthFill').style.background = 'linear-gradient(90deg, #ff5555, #ffaa77)';
        }

    let sunLight, hemiLight;

function openChest(chest, flapAmount) {
    if (chest.userData && chest.userData.opened) return;

    chest.userData.opened = true;

    addItemToInventory('flap', flapAmount);

    const warning = document.getElementById('takeoffWarning');
    warning.innerHTML = `🎁 CHEST OPENED! +${flapAmount} FLAPS`;
    warning.style.opacity = '1';
    warning.style.color = '#aaffaa';

    setTimeout(() => {
        warning.style.opacity = '0';
    }, 2200);

    // Lift the lid
    if (chest.children && chest.children.length > 0) {
        chest.children[0].position.y += 2;
    }
}

// Show prompt
function showOpenPrompt() {
    const warning = document.getElementById('takeoffWarning');
    warning.innerHTML = `🪵 PRESS E TO OPEN CHEST`;
    warning.style.opacity = '1';
    warning.style.color = '#ffdd88';
}



// Improved addItemToInventory
function addItemToInventory(type, count) {
    if (!ITEM_DB[type]) {
        console.warn(`Unknown item type: ${type}`);
        return;
    }

    // Try to stack first
    for (let i = 0; i < inventory.length; i++) {
        if (inventory[i] && inventory[i].type === type) {
            const maxStack = ITEM_DB[type].maxStack;
            const canAdd = maxStack - inventory[i].count;
            if (canAdd > 0) {
                const addAmount = Math.min(count, canAdd);
                inventory[i].count += addAmount;
                count -= addAmount;
                if (count <= 0) {
                    renderHotbar();
                    renderFullInventory();
                    return;
                }
            }
        }
    }

    // Find empty slot
    for (let i = 0; i < inventory.length; i++) {
        if (!inventory[i]) {
            inventory[i] = { type: type, count: count };
            renderHotbar();
            renderFullInventory();
            return;
        }
    }

    // Inventory full
    const warning = document.getElementById('takeoffWarning');
    warning.innerHTML = `❌ INVENTORY FULL!`;
    warning.style.opacity = '1';
    warning.style.color = '#ff6666';
    setTimeout(() => warning.style.opacity = '0', 2000);
}

function checkChestInteraction() {
    let nearAnyChest = false;

    // Starter runway chest
    if (chestMesh) {
        const dist = camera.position.distanceTo(chestMesh.position);
        if (dist < 25) {                    // ← Increased from 8 to 25
            nearAnyChest = true;
            showOpenPrompt();
            if (keys && keys['e']) {
                openChest(chestMesh, 60);
                keys['e'] = false;          // Prevent holding E from spamming
                return;
            }
        }
    }

    // House chests
    scene.traverse((obj) => {
        if (obj.userData && obj.userData.isHouseChest) {
            const dist = camera.position.distanceTo(obj.position);
            if (dist < 25) {                // ← Increased from 8 to 25
                nearAnyChest = true;
                showOpenPrompt();
                if (keys && keys['e']) {
                    openChest(obj, 128);
                    keys['e'] = false;
                    return;
                }
            }
        }
    });

    // Hide prompt when far away
    if (!nearAnyChest) {
        const warning = document.getElementById('takeoffWarning');
        if (warning.innerHTML.includes("PRESS E TO OPEN")) {
            warning.style.opacity = '0';
        }
    }
}










    function init() {
    initPerlin();
    initTextures();
    clock = new THREE.Clock();
    scene = new THREE.Scene();
    scene.fog = new THREE.FogExp2(0x88aaff, 0.0015);
    scene.background = new THREE.Color(0x88aaff);

    camera = new THREE.PerspectiveCamera(75, window.innerWidth / window.innerHeight, 0.3, 2600);
    camera.position.set(25, 45, 60);

    renderer = new THREE.WebGLRenderer({ antialias: true });
    renderer.setSize(window.innerWidth, window.innerHeight);
    renderer.setPixelRatio(window.devicePixelRatio);
    document.body.appendChild(renderer.domElement);

    hemiLight = new THREE.HemisphereLight(0xaaccff, 0x446644, 0.7);
    scene.add(hemiLight);
    sunLight = new THREE.DirectionalLight(0xffeedd, 1.3);
    sunLight.position.set(100, 150, 80);
    scene.add(sunLight);


    createWaterAndClouds();

    // === SPAWN RUNWAY SYSTEM ===
    spawnChunkX = Math.floor(camera.position.x / FLIGHT.chunkSize);
    spawnChunkZ = Math.floor(camera.position.z / FLIGHT.chunkSize);

    for (let dx = -FLIGHT.renderDist; dx <= FLIGHT.renderDist; dx++) {
        for (let dz = -FLIGHT.renderDist; dz <= FLIGHT.renderDist; dz++) {
            createChunk(spawnChunkX + dx, spawnChunkZ + dz);
        }
    }

    // Make starting chunk flat like a runway
    flattenSpawnRunway();

    // Spawn chest with starter loot
    spawnStarterChest();

    initInventory();
    renderHotbar();

    renderer.domElement.addEventListener('click', () => renderer.domElement.requestPointerLock());
    document.addEventListener('mousemove', e => {
        if (document.pointerLockElement === renderer.domElement) {
            targetYaw -= e.movementX * 0.0028;
            targetPitch -= e.movementY * 0.0028;
            targetPitch = Math.max(-1.2, Math.min(1.2, targetPitch));
        }
    });

    window.addEventListener('keydown', e => {
        const k = e.key.toLowerCase();

        if (k === 'w') move.forward = true;
        if (k === 's') move.backward = true;
        if (k === 'a') move.left = true;
        if (k === 'd') move.right = true;
        if (k === ' ') { spaceHeld = true; e.preventDefault(); }
        if (k === 'f') { flapPressed = true; e.preventDefault(); }
        if (k === 'j') { jetPressed = true; e.preventDefault(); }
        if (k === 'c') {
            if (craftingOpen) closeCrafting();
            else openCrafting();
        }
        if (e.key >= '1' && e.key <= '9') {
            selectedHotbar = parseInt(e.key) - 1;
            renderHotbar();
            renderFullInventory();
        }
        if (k === 'b') {
            const screen = document.getElementById('inventoryScreen');
            screen.style.display = screen.style.display === 'none' ? 'block' : 'none';
            if (screen.style.display === 'block') renderFullInventory();
        }

        // === KEYS OBJECT FOR CHECKING E ===
        keys[k] = true;
    });

    window.addEventListener('keyup', e => {
        const k = e.key.toLowerCase();
        if (k === 'w') move.forward = false;
        if (k === 's') move.backward = false;
        if (k === 'a') move.left = false;
        if (k === 'd') move.right = false;
        if (k === ' ') { spaceHeld = false; e.preventDefault(); }
        if (k === 'f') { flapPressed = false; e.preventDefault(); }
        if (k === 'j') { jetPressed = false; e.preventDefault(); }
        keys[k] = false;
    });
        // Left click to ram/attack hunters
    renderer.domElement.addEventListener('mousedown', (e) => {
        if (document.pointerLockElement === renderer.domElement && e.button === 0) {
            keys['click'] = true;
        }
    });

    window.addEventListener('resize', () => {
        camera.aspect = window.innerWidth / window.innerHeight;
        camera.updateProjectionMatrix();
        renderer.setSize(window.innerWidth, window.innerHeight);
    });
}
        function animate() {
        const delta = Math.min(clock.getDelta(), 0.033);
        const time = performance.now() * 0.002;

        yaw = THREE.MathUtils.lerp(yaw, targetYaw, 0.22);
        pitch = THREE.MathUtils.lerp(pitch, targetPitch, 0.22);
        camera.rotation.order = 'YXZ';
        camera.rotation.y = yaw;
        camera.rotation.x = pitch;

        updatePhysics(delta);
        updateHealth(delta);
        updateDayNight(delta);
        updateTrees(delta);           // ← important
        updateActiveTreeHP();         // ← important
        updateHunters(delta);
        updateOres(delta);
        updateStones(delta);
        updateBloodParticles(delta);
        updatePlanes(delta);
        updateBombs(delta);
        checkChestInteraction();
        updateChunks();

        if (waterMesh && waterMesh.geometry) {
            const pos = waterMesh.geometry.attributes.position;
            if (pos) {
                for (let i = 0; i < pos.count; i++) {
                    const x = pos.getX(i), z = pos.getZ(i);
                    pos.setY(i, Math.sin(x * 0.012 + time * 2.2) * 0.5 + Math.cos(z * 0.014 + time * 1.7) * 0.5);
                }
                pos.needsUpdate = true;
            }
        }
        if (cloudsGroup) {
            cloudsGroup.position.x = Math.sin(time * 0.012) * 60;
            cloudsGroup.position.z = Math.cos(time * 0.01) * 50;
        }

        renderer.render(scene, camera);
        requestAnimationFrame(animate);
    }

    init();
    animate();

</script>
