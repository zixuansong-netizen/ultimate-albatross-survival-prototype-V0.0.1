function updateTrees(delta) {
    const now = Date.now();
    updateTreeSway(delta);     // wind + shake

    for (let i = trees.length - 1; i >= 0; i--) {
        const tree = trees[i];
        if (!tree || !tree.userData) continue;

        const data = tree.userData;

        const dx = camera.position.x - tree.position.x;
        const dz = camera.position.z - tree.position.z;
        const dist = Math.hypot(dx, dz);

        // === RAMMING / CHOPPING TREE ===
        if (dist < 9 && keys['click'] && now - (lastAttackTime || 0) > 500) {
            keys['click'] = false;
            lastAttackTime = now;

            const speedKmh = Math.hypot(velocity.x, velocity.z) * 3.6;
            const toolMult = getToolMultiplier();
            const damage = Math.max(1, Math.floor(speedKmh / 2) * toolMult);

            data.health = Math.max(0, (data.health || 100) - damage);

            // Visual feedback
            data.shakeIntensity = Math.min(1.0, speedKmh / 80);
            triggerScreenRedFlash();
            showTreeHPBar(tree);

            // Player takes damage ONLY if not using tool
            const selectedItem = inventory[selectedHotbar];
            const isUsingTool = selectedItem && (selectedItem.type === 'wood' || selectedItem.type === 'axe');

            if (speedKmh > 20 && !isUsingTool) {
                playerHealth = Math.max(0, playerHealth - 10);
                const warning = document.getElementById('takeoffWarning');
                warning.innerHTML = `💥 TREE IMPACT! -10 HP`;
                warning.style.opacity = '1';
                warning.style.color = '#ff5555';
                setTimeout(() => warning.style.opacity = '0', 1000);
            }

            // Tree falls when HP reaches 0
            if (data.health <= 0 && !data.isFalling) {
                data.isFalling = true;
                data.fallDirection = new THREE.Vector3(dx, 0, dz).normalize();
                data.removeTime = now + 30000;

                addItemToInventory('wood', 60);

                const msg = document.getElementById('takeoffWarning');
                msg.innerHTML = `🌴 TREE CHOPPED! +60 WOOD`;
                msg.style.opacity = '1';
                msg.style.color = '#88ff88';
                setTimeout(() => msg.style.opacity = '0', 1500);

                if (activeTreeHP && activeTreeHP.tree === tree) {
                    if (activeTreeHP.element && activeTreeHP.element.parentNode) {
                        activeTreeHP.element.parentNode.removeChild(activeTreeHP.element);
                    }
                    activeTreeHP = null;
                }
            }
        }

        // Falling animation
        if (data.isFalling) {
            data.fallAngle += delta * 2.2;
            if (data.fallAngle > Math.PI / 2) data.fallAngle = Math.PI / 2;

            tree.rotation.z = data.fallDirection.x * data.fallAngle * 0.95;
            tree.rotation.x = -data.fallDirection.z * data.fallAngle * 0.95;

            if (now > data.removeTime) {
                scene.remove(tree);
                trees.splice(i, 1);
            }
        }
    }
}
