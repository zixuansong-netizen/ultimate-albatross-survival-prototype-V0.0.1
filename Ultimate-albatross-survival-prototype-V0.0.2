    if (!selected) return 1;

    switch(selected.type) {
        case 'axe':      return 1;   // Stone Axe
        case 'ironAxe':  return 5;   // Iron Axe
        case 'tungAxe':  return 10;  // Tungsten Axe
        case 'spear':    return 11;  // Tungsten Spear
