function createSlot(index) {
    const slot = document.createElement('div');
    slot.className = 'slot';
    slot.dataset.index = index;
    slot.draggable = true;

    const updateVisual = () => {
        const data = inventory[index];
        if (data) {
            slot.innerHTML = `
                <span>${ITEM_DB[data.type].emoji}</span>
                <span class="count">${data.count}</span>
            `;
            slot.style.borderColor = (index < 9 && index === selectedHotbar) ? '#aaffff' : ITEM_DB[data.type].color;
        } else {
            slot.innerHTML = '';
            slot.style.borderColor = (index < 9 && index === selectedHotbar) ? '#aaffff' : '#445566';
        }
    };
    updateVisual();

    // ==================== FIXED DRAG & DROP ====================
    slot.addEventListener('dragstart', e => {
        if (!inventory[index]) {
            e.preventDefault();
            return;
        }
        e.dataTransfer.setData('text/plain', index.toString());
        slot.style.opacity = '0.4';
    });

    slot.addEventListener('dragend', () => {
        slot.style.opacity = '1';
    });

    slot.addEventListener('dragover', e => {
        e.preventDefault();
        slot.style.borderColor = '#88ffff';
    });

    slot.addEventListener('dragleave', () => {
        updateVisual();
    });

    slot.addEventListener('drop', e => {
        e.preventDefault();
        const fromIndex = parseInt(e.dataTransfer.getData('text/plain'));
        if (fromIndex === index || !inventory[fromIndex]) return;

        const fromItem = inventory[fromIndex];
        let targetItem = inventory[index];

        if (!targetItem) {
            // Simple move
            inventory[index] = fromItem;
            inventory[fromIndex] = null;
        }
        else if (targetItem.type === fromItem.type && targetItem.type !== 'axe') {
            // Stack same items
            const max = ITEM_DB[fromItem.type].maxStack;
            const canAdd = max - targetItem.count;
            const move = Math.min(fromItem.count, canAdd);
            if (move > 0) {
                targetItem.count += move;
                fromItem.count -= move;
                if (fromItem.count <= 0) inventory[fromIndex] = null;
            }
        }
        else {
            // Swap different items
            inventory[index] = fromItem;
            inventory[fromIndex] = targetItem;
        }

        renderHotbar();
        renderFullInventory();
    });

    return slot;
}

