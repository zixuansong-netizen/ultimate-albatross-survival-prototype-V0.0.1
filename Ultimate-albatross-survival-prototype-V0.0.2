    function updateChunks() {
        const cx = Math.floor(camera.position.x / FLIGHT.chunkSize);
        const cz = Math.floor(camera.position.z / FLIGHT.chunkSize);
        const keep = new Set();
        for (let dx = -FLIGHT.renderDist; dx <= FLIGHT.renderDist; dx++) {
            for (let dz = -FLIGHT.renderDist; dz <= FLIGHT.renderDist; dz++) {
                const key = `${cx+dx},${cz+dz}`;
                keep.add(key);
                if (!chunks.has(key)) createChunk(cx+dx, cz+dz);
            }
        }
        for (let [key, data] of chunks) {
            if (!keep.has(key)) {
                scene.remove(data.terrain);
                if (data.grass) scene.remove(data.grass);
                chunks.delete(key);
            }
        }
        document.getElementById('debugInfo').innerHTML = `🌍 CHUNKS: ${chunks.size}`;
    }

