<script type="module">
    import * as THREE from 'three';

    // ==================== REAL FLIGHT PHYSICS ====================
    const FLIGHT = {
        chunkSize: 150,
        renderDist: 4,
        waterLevel: 5.8,
        gravity: -14.0,
        flapForce: 12.5,
        flapRegenRate: 0.22,
        glideRatio: 22.0,
        takeoffSpeed: 28,
        groundAccel: 24,
        maxAirSpeed: 200,
        minAirSpeed: 14,
        airDrag: 0.999,
        thermalLift: 8.5,
        alignmentStrength: 0.16,
        jetBoostAccel: 9.8,
        jetDuration: 5.0
    };

    // ==================== INVENTORY SYSTEM ====================
    let playerHealth = 150;
    const MAX_HEALTH = 150;
    let planes = [];
    let bombs = [];
    let lastBombTime = 0;
    let lastRegenTime = Date.now();
    let inventory = Array(36).fill(null);
    let selectedHotbar = 0;
    let lastSpeedOnGround = 0;   // Used to detect hard landing
    const ITEM_DB = {
        flap:   { emoji: '🪶', maxStack: 64, color: '#66ccff' },
        jet:    { emoji: '🧨', maxStack: 64, color: '#ffaa66' },
        stone:  { emoji: '🥌', maxStack: 16, color: '#888888' },
        wood:   { emoji: '🪵', maxStack: 64, color: '#d2a679' },
        axe:    { emoji: '🪓', maxStack: 1, color: '#cccccc' },     // Stone Axe
        iron:   { emoji: '⛏️', maxStack: 32, color: '#aaaaaa' },    // Iron Ore
        tungsten: { emoji: '⚒️', maxStack: 16, color: '#7777ff' }, // Tungsten Ore
        ironAxe:  { emoji: '🪓', maxStack: 1, color: '#ffcc88' },   // Iron Axe
        tungAxe:  { emoji: '🪓', maxStack: 1, color: '#8888ff' },   // Tungsten Axe
        spear:    { emoji: '🔱', maxStack: 1, color: '#99ccff' }    // Tungsten Spear
    };
    // ==================== BASIC CRAFTING SYSTEM (Step 2) ====================
// ==================== CLEAN AUTO-CRAFTING ====================
let craftingOpen = false;

const RECIPES = [
    {
        name: "Stone Axe",
        emoji: "🪓",
        result: { type: "axe", count: 1 },
        ingredients: [
            { type: "wood", count: 4, emoji: "🪵" },
            { type: "stone", count: 2, emoji: "🥌" }
        ]
    },
    {
        name: "Iron Axe",
        emoji: "🪓",
        result: { type: "ironAxe", count: 1 },
        ingredients: [
            { type: "wood", count: 2, emoji: "🪵" },
            { type: "stone", count: 1, emoji: "🥌" },
            { type: "iron", count: 1, emoji: "⛏️" }
        ]
    },
    {
        name: "Tungsten Axe",
        emoji: "🪓",
        result: { type: "tungAxe", count: 1 },
        ingredients: [
            { type: "wood", count: 2, emoji: "🪵" },
            { type: "tungsten", count: 1, emoji: "⚒️" }
        ]
    },
    {
        name: "Tungsten Spear",
        emoji: "🔱",
        result: { type: "spear", count: 1 },
        ingredients: [
            { type: "stone", count: 2, emoji: "🥌" },
            { type: "tungsten", count: 1, emoji: "⚒️" }
        ]
    }
];
// Spawn Iron Ore - 4 per chunk
function spawnIronOreInChunk(cx, cz) {
    const key = `iron_${cx},${cz}`;
    if (houseData.has(key)) return;

    const worldOffsetX = cx * FLIGHT.chunkSize;
    const worldOffsetZ = cz * FLIGHT.chunkSize;

    for (let i = 0; i < 4; i++) {
        let attempts = 0;
        let placed = false;

        while (attempts < 15 && !placed) {
            attempts++;

            const localX = (Math.random() - 0.5) * (FLIGHT.chunkSize - 40);
            const localZ = (Math.random() - 0.5) * (FLIGHT.chunkSize - 40);

            const worldX = worldOffsetX + localX;
            const worldZ = worldOffsetZ + localZ;

            const { height } = getTerrainHeightAndBiome(worldX, worldZ);

            if (height > FLIGHT.waterLevel + 3) {
                createIronOre(worldX, height + 1.2, worldZ);
                placed = true;
            }
        }
    }
    houseData.set(key, true);
}

// Spawn Tungsten Ore - 1 per chunk (rarer)
function spawnTungstenOreInChunk(cx, cz) {
    const key = `tungsten_${cx},${cz}`;
    if (houseData.has(key)) return;

    const worldOffsetX = cx * FLIGHT.chunkSize;
    const worldOffsetZ = cz * FLIGHT.chunkSize;

    const localX = (Math.random() - 0.5) * (FLIGHT.chunkSize - 50);
    const localZ = (Math.random() - 0.5) * (FLIGHT.chunkSize - 50);

    const worldX = worldOffsetX + localX;
    const worldZ = worldOffsetZ + localZ;

    const { height } = getTerrainHeightAndBiome(worldX, worldZ);

    if (height > FLIGHT.waterLevel + 5) {
        createTungstenOre(worldX, height + 1.5, worldZ);
    }

    houseData.set(key, true);
}
function createIronOre(x, y, z) {
    const group = new THREE.Group();

    // Rusty iron ore
    const oreMat = new THREE.MeshStandardMaterial({
        color: 0xaa6644,
        roughness: 0.9,
        metalness: 0.3
    });

    const main = new THREE.Mesh(new THREE.DodecahedronGeometry(1.4, 1), oreMat);
    main.position.set(0, y, 0);
    group.add(main);

    // Smaller rusty bits
    for (let i = 0; i < 4; i++) {
        const small = new THREE.Mesh(new THREE.DodecahedronGeometry(0.6, 0), oreMat);
        small.position.set(
            (Math.random()-0.5)*1.8,
            y - 0.4 + Math.random()*0.8,
            (Math.random()-0.5)*1.8
        );
        group.add(small);
    }

    group.userData = { type: 'iron', health: 300 };
    group.position.set(x, 0, z);
    scene.add(group);
    return group;
}

function createTungstenOre(x, y, z) {
    const group = new THREE.Group();

    // Shiny blue-gold tungsten
    const oreMat = new THREE.MeshStandardMaterial({
        color: 0x7799ff,
        emissive: 0x3344aa,
        metalness: 0.85,
        roughness: 0.4
    });

    const main = new THREE.Mesh(new THREE.DodecahedronGeometry(1.6, 1), oreMat);
    main.position.set(0, y, 0);
    group.add(main);

    group.userData = { type: 'tungsten', health: 400 };
    group.position.set(x, 0, z);
    scene.add(group);
    return group;
}



function openCrafting() {
    craftingOpen = true;
    document.getElementById('craftingScreen').style.display = 'block';
    renderRecipes();
}

function closeCrafting() {
    craftingOpen = false;
    document.getElementById('craftingScreen').style.display = 'none';
}

function renderRecipes() {
    const container = document.getElementById('recipesList');
    container.innerHTML = '';

    RECIPES.forEach((recipe, index) => {
        const canCraft = recipe.ingredients.every(ing => getTotal(ing.type) >= ing.count);

        const div = document.createElement('div');
        div.style.cssText = `
            background: rgba(30,35,55,0.9);
            border: 2px solid ${canCraft ? '#88ffaa' : '#555577'};
            border-radius: 14px;
            padding: 18px 20px;
            display: flex;
            align-items: center;
            gap: 20px;
            cursor: ${canCraft ? 'pointer' : 'not-allowed'};
            transition: all 0.2s;
        `;

        if (canCraft) {
            div.style.boxShadow = '0 0 15px rgba(136,255,170,0.3)';
        }

        div.innerHTML = `
            <div style="font-size:52px; width:70px;">${recipe.emoji}</div>
            <div style="flex:1;">
                <div style="font-size:19px; font-weight:bold;">${recipe.name}</div>
                <div style="font-size:14px; color:#aaccff; margin-top:4px;">
                    ${recipe.ingredients.map(ing => `${ing.count} ${ing.emoji}`).join(' + ')}
                </div>
            </div>
            <div style="font-size:22px; color:${canCraft ? '#88ffaa' : '#666688'};">→</div>
        `;

        if (canCraft) {
            div.addEventListener('click', () => craftRecipe(index));
        }

        container.appendChild(div);
    });
}

function craftRecipe(recipeIndex) {
    const recipe = RECIPES[recipeIndex];
    const canCraft = recipe.ingredients.every(ing => getTotal(ing.type) >= ing.count);

    if (!canCraft) return;

    // Remove ingredients
    recipe.ingredients.forEach(ing => {
        let remaining = ing.count;
        for (let i = 0; i < inventory.length && remaining > 0; i++) {
            if (inventory[i] && inventory[i].type === ing.type) {
                const take = Math.min(remaining, inventory[i].count);
                inventory[i].count -= take;
                remaining -= take;
                if (inventory[i].count <= 0) inventory[i] = null;
            }
        }
    });

    // Give result
    addItemToInventory(recipe.result.type, recipe.result.count);

    renderHotbar();
    renderFullInventory();
    renderRecipes();

    // Success message
    const msg = document.getElementById('takeoffWarning');
    msg.innerHTML = `🪓 ${recipe.name} CRAFTED!`;
    msg.style.opacity = '1';
    msg.style.color = '#aaffaa';
    setTimeout(() => msg.style.opacity = '0', 2000);

    // AUTO CLOSE crafting screen after successful craft
    setTimeout(() => {
        closeCrafting();
    }, 800);   // closes after 0.8 seconds
}
function createHuntingPlane(x, y, z) {
    const planeGroup = new THREE.Group();

    // Fuselage (white)
    const bodyMat = new THREE.MeshStandardMaterial({ color: 0xf0f0f0, roughness: 0.5 });
    const fuselage = new THREE.Mesh(new THREE.BoxGeometry(9, 3.2, 2.8), bodyMat);
    fuselage.position.set(0, y + 8, 0);
    planeGroup.add(fuselage);

    // Red stripe on fuselage
    const stripeMat = new THREE.MeshStandardMaterial({ color: 0xff2222 });
    const stripe = new THREE.Mesh(new THREE.BoxGeometry(9.1, 0.6, 2.9), stripeMat);
    stripe.position.set(0, y + 7.2, 0);
    planeGroup.add(stripe);

    // Wings (high-wing Cessna style)
    const wingMat = new THREE.MeshStandardMaterial({ color: 0xffffff, roughness: 0.6 });
    const wings = new THREE.Mesh(new THREE.BoxGeometry(20, 0.8, 4), wingMat);
    wings.position.set(0, y + 9.5, 0);
    planeGroup.add(wings);

    // Tail wings
    const tailWing = new THREE.Mesh(new THREE.BoxGeometry(6, 0.6, 3), wingMat);
    tailWing.position.set(-6, y + 9.8, 0);
    planeGroup.add(tailWing);

    // Vertical stabilizer
    const tailFin = new THREE.Mesh(new THREE.BoxGeometry(0.8, 5, 2), bodyMat);
    tailFin.position.set(-6.5, y + 11, 0);
    planeGroup.add(tailFin);

    // Propeller + nose
    const noseMat = new THREE.MeshStandardMaterial({ color: 0xff4444 });
    const nose = new THREE.Mesh(new THREE.ConeGeometry(1.4, 3, 12), noseMat);
    nose.position.set(5, y + 8, 0);
    nose.rotation.x = Math.PI / 2;
    planeGroup.add(nose);

    const prop = new THREE.Mesh(new THREE.BoxGeometry(0.5, 5, 0.5), new THREE.MeshStandardMaterial({ color: 0x222222 }));
    prop.position.set(6.5, y + 8, 0);
    planeGroup.add(prop);

    planeGroup.userData = {
        health: 1000,
        lastBombTime: 0,
        wingFold: 0,           // 0 = normal, 1 = folded, 2 = fully folded
        stallTimer: 0,
        velocity: new THREE.Vector3(0, 0, 0)
    };

    planeGroup.position.set(x, y + 30, z); // spawn high
    scene.add(planeGroup);
    planes.push(planeGroup);

    return planeGroup;
}
function updatePlanes(delta) {
    const now = Date.now();

    for (let i = planes.length - 1; i >= 0; i--) {
        const plane = planes[i];
        if (!plane || !plane.userData) continue;

        const data = plane.userData;

        // Despawn at night
        if (isNight) {
            scene.remove(plane);
            planes.splice(i, 1);
            continue;
        }

        // Improved chase + physics
        const dx = camera.position.x - plane.position.x;
        const dy = (camera.position.y + 12) - plane.position.y;
        const dz = camera.position.z - plane.position.z;
        const dist = Math.hypot(dx, dz, dy);

        let speed = 32;

        // Wing fold effect (dive mode)
        if (data.wingFold === 1) speed = 45;      // folded = faster dive
        if (data.wingFold === 2) speed = 58;      // fully folded = very fast dive

        plane.position.x += (dx / dist) * speed * delta;
        plane.position.y += (dy / dist) * speed * 0.7 * delta;
        plane.position.z += (dz / dist) * speed * delta;

        // Face player smoothly
        plane.lookAt(camera.position.x, plane.position.y + 8, camera.position.z);

        // Random stall chance
        if (Math.random() < 0.008) {
            data.stallTimer = 3.0;   // stall for 3 seconds
        }

        if (data.stallTimer > 0) {
            data.stallTimer -= delta;
            plane.position.y -= 15 * delta;   // fall during stall
            plane.rotation.z = Math.sin(now * 0.02) * 0.6; // wobble
        }

        // Shoot bombs
        if (dist < 140 && now - data.lastBombTime > 5000) {
            data.lastBombTime = now;
            shootBombFromPlane(plane);
        }

        // Player attack on plane
        if (dist < 30 && keys['click'] && now - lastAttackTime > 300) {
            keys['click'] = false;
            lastAttackTime = now;

            const toolMult = getToolMultiplier();
            const damage = Math.max(8, 25 * toolMult);

            data.health -= damage;

            const warning = document.getElementById('takeoffWarning');
            warning.innerHTML = `💥 PLANE HIT! (${Math.ceil(data.health)}/1000)`;
            warning.style.opacity = '1';
            warning.style.color = '#ffaa66';
            setTimeout(() => warning.style.opacity = '0', 700);

            if (data.health <= 0) {
                scene.remove(plane);
                planes.splice(i, 1);

                const msg = document.getElementById('takeoffWarning');
                msg.innerHTML = `💥 HUNTING PLANE DESTROYED!`;
                msg.style.opacity = '1';
                msg.style.color = '#aaffaa';
                setTimeout(() => msg.style.opacity = '0', 1800);
            }
        }
    }
}
function shootBombFromPlane(plane) {
    const bomb = new THREE.Mesh(
        new THREE.SphereGeometry(1.4, 8, 8),
        new THREE.MeshStandardMaterial({ color: 0x222222, emissive: 0x440000, metalness: 0.6 })
    );

    bomb.position.copy(plane.position);
    bomb.position.y -= 5;

    const dir = new THREE.Vector3(
        camera.position.x - plane.position.x,
        camera.position.y - plane.position.y - 10,
        camera.position.z - plane.position.z
    ).normalize();

    bomb.userData = {
        velocity: dir.multiplyScalar(28),
        life: 12,
        damage: 10
    };

    scene.add(bomb);
    bombs.push(bomb);
}
function updateBombs(delta) {
    const now = Date.now();

    for (let i = bombs.length - 1; i >= 0; i--) {
        const bomb = bombs[i];
        if (!bomb) continue;

        bomb.userData.velocity.y -= 28 * delta;   // gravity
        bomb.position.addScaledVector(bomb.userData.velocity, delta);

        bomb.rotation.x += delta * 8;

        bomb.userData.life -= delta;

        // Check hit player
        const distToPlayer = bomb.position.distanceTo(camera.position);
        if (distToPlayer < 4) {
            let damage = bomb.userData.damage;

            // Right-click block (1/8 damage)
            if (keys['rightClick']) {
                damage = Math.floor(damage / 8);
            }

            playerHealth = Math.max(0, playerHealth - damage);

            const warning = document.getElementById('takeoffWarning');
            warning.innerHTML = `💣 BOMB HIT! -${damage} HP`;
            warning.style.opacity = '1';
            warning.style.color = '#ff4444';
            setTimeout(() => warning.style.opacity = '0', 900);

            scene.remove(bomb);
            bombs.splice(i, 1);
            continue;
        }

        if (bomb.userData.life <= 0) {
            scene.remove(bomb);
            bombs.splice(i, 1);
        }
    }
}

function getToolMultiplier() {
