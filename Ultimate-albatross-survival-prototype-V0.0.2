// ==================== ORE MINING SYSTEM ====================
function updateOres(delta) {
    const now = Date.now();

    // Make a copy of children to avoid modification during traversal
    const objectsToCheck = [];

    scene.traverse((obj) => {
        if (obj.userData && (obj.userData.type === 'iron' || obj.userData.type === 'tungsten')) {
            objectsToCheck.push(obj);
        }
    });

    for (let i = 0; i < objectsToCheck.length; i++) {
        const obj = objectsToCheck[i];
        if (!obj || !obj.userData) continue;

        const dx = camera.position.x - obj.position.x;
        const dz = camera.position.z - obj.position.z;
        const dist = Math.hypot(dx, dz);

        if (dist < 9 && keys['click'] && now - (lastAttackTime || 0) > 400) {
            keys['click'] = false;
            lastAttackTime = now;

            const speedKmh = Math.hypot(velocity.x, velocity.z) * 3.6;
            const toolMult = getToolMultiplier();
            let damage = Math.max(1, Math.floor(speedKmh / 4) * toolMult);

            const selectedItem = inventory[selectedHotbar];
            const isUsingTool = selectedItem &&
                (selectedItem.type === 'wood' ||
                 selectedItem.type === 'axe' ||
                 selectedItem.type === 'ironAxe' ||
                 selectedItem.type === 'tungAxe' ||
                 selectedItem.type === 'spear');

            if (speedKmh > 25 && !isUsingTool) {
                playerHealth = Math.max(0, playerHealth - 6);
                const warning = document.getElementById('takeoffWarning');
                warning.innerHTML = `💥 ORE IMPACT! -6 HP`;
                warning.style.opacity = '1';
                warning.style.color = '#ff5555';
                setTimeout(() => warning.style.opacity = '0', 900);
            }

            obj.userData.health = (obj.userData.health || 300) - damage;

            // Feedback
            const warning = document.getElementById('takeoffWarning');
            warning.innerHTML = `⛏️ MINING... (${Math.max(0, Math.ceil(obj.userData.health))} HP)`;
            warning.style.opacity = '1';
            warning.style.color = '#aaffaa';
            setTimeout(() => warning.style.opacity = '0', 600);

            if (obj.userData.health <= 0) {
                const oreType = obj.userData.type;
                const dropAmount = 1;

                addItemToInventory(oreType, dropAmount);

                const msg = document.getElementById('takeoffWarning');
                msg.innerHTML = oreType === 'iron' ?
                    `⛏️ IRON ORE MINED! +1` :
                    `⚒️ TUNGSTEN ORE MINED! +1`;
                msg.style.opacity = '1';
                msg.style.color = '#dddddd';
                setTimeout(() => msg.style.opacity = '0', 1400);

                // Safe removal
                scene.remove(obj);
            }
        }
    }
