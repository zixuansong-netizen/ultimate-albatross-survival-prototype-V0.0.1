    function fade(t) { return t*t*t*(t*(t*6-15)+10); }
    function lerp(a,b,t) { return a + t*(b-a); }
    function grad3(hash, x, y, z) {
        const h = hash & 15;
        const u = h < 8 ? x : y;
        const v = h < 4 ? y : (h === 12 || h === 14 ? x : z);
        return ((h&1)===0 ? u : -u) + ((h&2)===0 ? v : -v);
    }
    function perlin3D(x, y, z) {
        let X = Math.floor(x) & 255, Y = Math.floor(y) & 255, Z = Math.floor(z) & 255;
        x -= Math.floor(x); y -= Math.floor(y); z -= Math.floor(z);
        const u = fade(x), v = fade(y), w = fade(z);
        const aaa = perlinPerm[perlinPerm[perlinPerm[X] + Y] + Z];
        const aba = perlinPerm[perlinPerm[perlinPerm[X] + Y+1] + Z];
        const aab = perlinPerm[perlinPerm[perlinPerm[X] + Y] + Z+1];
        const abb = perlinPerm[perlinPerm[perlinPerm[X] + Y+1] + Z+1];
        const baa = perlinPerm[perlinPerm[perlinPerm[X+1] + Y] + Z];
        const bba = perlinPerm[perlinPerm[perlinPerm[X+1] + Y+1] + Z];
        const bab = perlinPerm[perlinPerm[perlinPerm[X+1] + Y] + Z+1];
        const bbb = perlinPerm[perlinPerm[perlinPerm[X+1] + Y+1] + Z+1];
        let x1 = lerp(grad3(aaa,x,y,z), grad3(baa,x-1,y,z), u);
        let x2 = lerp(grad3(aba,x,y-1,z), grad3(bba,x-1,y-1,z), u);
        let y1 = lerp(x1, x2, v);
        x1 = lerp(grad3(aab,x,y,z-1), grad3(bab,x-1,y,z-1), u);
        x2 = lerp(grad3(abb,x,y-1,z-1), grad3(bbb,x-1,y-1,z-1), u);
        let y2 = lerp(x1, x2, v);
        return (lerp(y1, y2, w) + 1) * 0.5;
    }

    function getTerrainHeightAndBiome(wx, wz) {
        let h = 0, amp = 52, freq = 0.0034;
        for (let i = 0; i < 5; i++) {
            h += (perlin3D(wx * freq, 0, wz * freq) * 2 - 1) * amp;
            amp *= 0.46; freq *= 2.18;
        }
        const noise = perlin3D(wx * 0.0012, 12, wz * 0.0012);
        let biome = 'meadow';
        if (noise > 0.68) biome = 'taiga';
        else if (noise > 0.45) biome = 'savanna';
        else if (noise < 0.22) biome = 'desert';
        const height = Math.max(h + 9, 3.2);
        return { height, biome };
    }
