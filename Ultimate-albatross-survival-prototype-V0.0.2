function spawnHousesInChunk(cx, cz) {
    const key = `${cx},${cz}`;

    // Prevent spawning houses multiple times in the same chunk
    if (houseData.has(key)) return;

    const chunkHouses = [];
    const worldOffsetX = cx * FLIGHT.chunkSize;
    const worldOffsetZ = cz * FLIGHT.chunkSize;

    // How many houses per chunk? (0–2 is nice and natural)
    const numHouses = Math.random() < 0.35 ? 1 : (Math.random() < 0.12 ? 2 : 0);

    for (let i = 0; i < numHouses; i++) {
        // Random position inside this chunk
        const localX = (Math.random() - 0.5) * (FLIGHT.chunkSize - 40);
        const localZ = (Math.random() - 0.5) * (FLIGHT.chunkSize - 40);

        const worldX = worldOffsetX + localX;
        const worldZ = worldOffsetZ + localZ;

        const { height } = getTerrainHeightAndBiome(worldX, worldZ);

        // Only spawn on solid land, not too close to water
        if (height > FLIGHT.waterLevel + 3) {
            createSimpleHouse(worldX, height + 0.1, worldZ);
            chunkHouses.push({x: worldX, z: worldZ});
        }
    }

    if (chunkHouses.length > 0) {
        houseData.set(key, chunkHouses);
    }
}

